<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayBackdrop"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="28dp"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="250dp"
            android:layout_height="330dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="16dp"
            app:cardCornerRadius="22dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:strokeColor="#80FFFFFF"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivOverlayPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/photo_preview"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="#55000000"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/tvOverlayPhotoName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOverlayPhotoDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLines="2"
                        android:textColor="#DDFFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_action_sheet"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/rowFavorite"
                style="@style/OverlayActionRow"
                android:drawableEnd="@android:drawable/btn_star_big_off"
                android:text="@string/favorite" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#30FFFFFF" />

            <TextView
                android:id="@+id/rowSetPrivate"
                style="@style/OverlayActionRow"
                android:drawableEnd="@drawable/ic_lock"
                android:text="@string/set_as_private" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#30FFFFFF" />

            <TextView
                android:id="@+id/rowDelete"
                style="@style/OverlayActionRow"
                android:drawableEnd="@drawable/ic_delete"
                android:text="@string/delete_photo"
                android:textColor="#FF6B63" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
