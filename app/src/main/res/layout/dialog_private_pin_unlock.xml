<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="34dp"
    android:layout_marginVertical="22dp"
    android:background="@drawable/bg_private_pin_modal"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvPinModalTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/private_unlock_title"
        android:textColor="#111827"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPinModalSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/private_unlock_modal_subtitle"
        android:textColor="#6B7280"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etPinDigit1"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_private_pin_digit"
            android:gravity="center"
            android:hint="•"
            android:importantForAutofill="no"
            android:inputType="textPassword"
            android:maxLength="1"
            android:textColor="#111827"
            android:textColorHint="#9CA3AF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPinDigit2"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_private_pin_digit"
            android:gravity="center"
            android:hint="•"
            android:importantForAutofill="no"
            android:inputType="textPassword"
            android:maxLength="1"
            android:textColor="#111827"
            android:textColorHint="#9CA3AF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPinDigit3"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_private_pin_digit"
            android:gravity="center"
            android:hint="•"
            android:importantForAutofill="no"
            android:inputType="textPassword"
            android:maxLength="1"
            android:textColor="#111827"
            android:textColorHint="#9CA3AF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPinDigit4"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_private_pin_digit"
            android:gravity="center"
            android:hint="•"
            android:importantForAutofill="no"
            android:inputType="textPassword"
            android:maxLength="1"
            android:textColor="#111827"
            android:textColorHint="#9CA3AF"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPinError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#B00020"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPinCancel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_private_pin_button_secondary"
            android:text="@android:string/cancel"
            android:textAllCaps="false"
            android:textColor="#374151"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPinVerify"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_private_pin_button_primary"
            android:text="@string/unlock"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvForgotPin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/private_forgot_pin_modal_action"
        android:textColor="#6B7280"
        android:textSize="13sp" />

</LinearLayout>
