<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="34dp"
    android:layout_marginVertical="22dp"
    android:background="@drawable/bg_private_pin_modal"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/private_forgot_pin_title"
        android:textColor="#111827"
        android:textSize="23sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/private_answer_question_prefix"
        android:textColor="#6B7280"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvRecoveryQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:paddingVertical="2dp"
        android:textColor="#111827"
        android:textSize="16sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etRecoveryAnswer"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_private_pin_button_secondary"
        android:hint="@string/private_security_answer_hint"
        android:inputType="textCapSentences"
        android:paddingHorizontal="12dp"
        android:textColor="#111827"
        android:textColorHint="#9CA3AF"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvRecoveryError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#B00020"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRecoveryCancel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_private_pin_button_secondary"
            android:text="@android:string/cancel"
            android:textAllCaps="false"
            android:textColor="#374151"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRecoveryVerify"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_private_pin_button_primary"
            android:text="@string/verify"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
